# ─── Required ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-your-key-here
# Get a key at: https://openrouter.ai

# ─── Model selection ──────────────────────────────────────────────────────────
# Default model used when agents don't specify one.
# Any model ID from https://openrouter.ai/models works.

DEFAULT_MODEL=deepseek/deepseek-chat          # fast, cheap, great default

# Premium options (best quality, 1M+ context):
# DEFAULT_MODEL=openai/gpt-5.4-pro             # OpenAI flagship
# DEFAULT_MODEL=openai/gpt-5.4                 # GPT-5.4 (1M ctx)
# DEFAULT_MODEL=anthropic/claude-opus-4.6      # Anthropic flagship (1M ctx)
# DEFAULT_MODEL=anthropic/claude-sonnet-4.6    # Anthropic fast + smart (1M ctx)
# DEFAULT_MODEL=x-ai/grok-4.20-beta            # xAI Grok 4.20 (2M ctx)

# Budget options (low cost per token):
# DEFAULT_MODEL=openai/gpt-5.4-mini            # GPT-5.4 Mini (400k ctx)
# DEFAULT_MODEL=openai/gpt-5.4-nano            # GPT-5.4 Nano (400k ctx)
# DEFAULT_MODEL=mistralai/mistral-small-2603   # Mistral Small 4 (262k ctx)
# DEFAULT_MODEL=deepseek/deepseek-r1           # strong reasoning
# DEFAULT_MODEL=google/gemini-2.0-flash-001    # fast Gemini
# DEFAULT_MODEL=qwen/qwen-2.5-72b-instruct     # multilingual

# Free tier (no credits needed):
# DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b  # NVIDIA 120B (262k ctx)
# DEFAULT_MODEL=qwen/qwen3.5-9b                    # Qwen 3.5 9B (256k ctx)
# DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct  # Llama 3.3 70B

# ─── Optional ─────────────────────────────────────────────────────────────────
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SUMMARY_TRIGGER_TURNS=6    # auto-summary fires after this many agent turns
PORT=7860                   # Gradio server port
HOST=0.0.0.0               # Gradio server host
